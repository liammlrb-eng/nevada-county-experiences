# API keys — never commit
scraper/config.py

# Local backups
*.bak

# Python
__pycache__/
*.pyc
*.pyo
.env

# Scraper runtime outputs
# events.json IS committed so the GitHub Pages demo has live data.
# After each scrape, run: git add scraper_output/events.json && git commit && git push
scraper_output/candidates.json
scraper_output/snapshots/

# Excel inventory (large binary)
inventory.xlsx

# Test runtime outputs. The visual-regression BASELINES
# (tests/__snapshots__/home-*.png) ARE committed — they're the reference
# images. Only the per-run diff artifacts and pytest/Playwright scratch are
# ignored.
.pytest_cache/
test-results/
tests/__snapshots__/_diffs/
